#include<bits/stdc++.h>
using namespace std;
#define ll long long

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    ll n, k;
    cin >> n >> k;
    vector<ll> a(n);
    for(ll i = 0; i < n; i++) {
        cin >> a[i];
    }
    multiset<ll> w(a.begin(), a.begin() + k);
    auto mid = next(w.begin(), k / 2);
    for(ll i = k; ; i++) {
        cout << (k % 2 ? *mid : *prev(mid)) << ' ';
        if(i == n)
            break;
        w.insert(a[i]);
        if(a[i] < *mid)
            mid--;
        if(a[i - k] <= *mid)
            mid++;
        w.erase(w.lower_bound(a[i - k]));
    }
    cout << endl;
    return 0;
}
